# Copy this file to .env and fill in real values. Never commit .env itself.

PORT=5000
NODE_ENV=development

# Local PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/hackathon_db?schema=public"

# Frontend origin allowed for CORS
CLIENT_ORIGIN="http://localhost:5173"

# Auth
JWT_SECRET="change-me"
JWT_EXPIRES_IN="8h"
SEED_ADMIN_EMAIL="admin@assetflow.local"
SEED_ADMIN_PASSWORD="Admin@123"

# AI service (if your teammate exposes a separate FastAPI/Python service)
AI_SERVICE_URL="http://localhost:8000"
