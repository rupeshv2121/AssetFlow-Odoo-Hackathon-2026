// AssetFlow schema — draft for team review
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURN_REQUESTED
  RETURNED
}

enum AllocationRequestType {
  ALLOCATION
  TRANSFER
}

enum AllocationRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditResult {
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_APPROVED
  OVERDUE_RETURN
  AUDIT_DISCREPANCY
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(EMPLOYEE)
  status       UserStatus @default(ACTIVE)
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  departmentId String?
  department   Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  headOfDepartments    Department[]         @relation("DepartmentHead")
  allocationsHeld      Allocation[]         @relation("AllocationEmployee")
  allocationRequestsMade     AllocationRequest[] @relation("AllocationRequestRequestedBy")
  allocationRequestsFrom     AllocationRequest[] @relation("AllocationRequestFromEmployee")
  allocationRequestsTo       AllocationRequest[] @relation("AllocationRequestToEmployee")
  allocationRequestsApproved AllocationRequest[] @relation("AllocationRequestApprovedBy")
  bookingsMade         Booking[]            @relation("BookingUser")
  maintenanceRaised    MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceApproved  MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  auditCyclesCreated   AuditCycle[]         @relation("AuditCreatedBy")
  auditorAssignments   AuditCycleAuditor[]
  notifications        Notification[]
  activityLogs         ActivityLog[]

  @@index([departmentId])
}

model Department {
  id        String           @id @default(uuid())
  name      String
  headId    String?          @unique
  head      User?            @relation("DepartmentHead", fields: [headId], references: [id])
  parentId  String?
  parent    Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[]     @relation("DepartmentHierarchy")
  status    DepartmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  employees   User[]       @relation("DepartmentEmployees")
  allocations Allocation[] @relation("AllocationDepartment")
  allocationRequestsFrom AllocationRequest[] @relation("AllocationRequestFromDepartment")
  allocationRequestsTo   AllocationRequest[] @relation("AllocationRequestToDepartment")
  bookings    Booking[]    @relation("BookingDepartment")

  @@index([parentId])
}

model AssetCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  extraFields Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]
}

model Asset {
  id              String    @id @default(uuid())
  assetTag        String    @unique
  name            String
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Decimal?  @db.Decimal(12, 2)
  condition       String?
  location        String?
  isBookable      Boolean   @default(false)
  status          AssetStatus @default(AVAILABLE)
  photoUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  allocations         Allocation[]
  allocationRequests  AllocationRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  @@index([categoryId])
  @@index([status])
}

model Allocation {
  id                 String    @id @default(uuid())
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id])
  employeeId         String?
  employee           User?     @relation("AllocationEmployee", fields: [employeeId], references: [id])
  departmentId       String?
  department         Department? @relation("AllocationDepartment", fields: [departmentId], references: [id])
  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  returnRequestedAt  DateTime?
  returnedAt         DateTime?
  returnCondition    String?
  status             AllocationStatus @default(ACTIVE)
  createdAt          DateTime  @default(now())

  @@index([assetId, status])
  @@index([employeeId])
}

model AllocationRequest {
  id               String   @id @default(uuid())
  assetId          String
  asset            Asset    @relation(fields: [assetId], references: [id])
  type             AllocationRequestType
  requestedById    String
  requestedBy      User     @relation("AllocationRequestRequestedBy", fields: [requestedById], references: [id])
  fromEmployeeId   String?
  fromEmployee     User?    @relation("AllocationRequestFromEmployee", fields: [fromEmployeeId], references: [id])
  fromDepartmentId String?
  fromDepartment   Department? @relation("AllocationRequestFromDepartment", fields: [fromDepartmentId], references: [id])
  toEmployeeId     String?
  toEmployee       User?    @relation("AllocationRequestToEmployee", fields: [toEmployeeId], references: [id])
  toDepartmentId   String?
  toDepartment     Department? @relation("AllocationRequestToDepartment", fields: [toDepartmentId], references: [id])
  status           AllocationRequestStatus @default(REQUESTED)
  approvedById     String?
  approvedBy       User?    @relation("AllocationRequestApprovedBy", fields: [approvedById], references: [id])
  createdAt        DateTime @default(now())
  resolvedAt       DateTime?

  @@index([assetId, status])
}

model Booking {
  id           String   @id @default(uuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])
  bookedById   String
  bookedBy     User     @relation("BookingUser", fields: [bookedById], references: [id])
  departmentId String?
  department   Department? @relation("BookingDepartment", fields: [departmentId], references: [id])
  purpose      String?
  startTime    DateTime
  endTime      DateTime
  status       BookingStatus @default(UPCOMING)
  createdAt    DateTime @default(now())

  @@index([assetId, startTime, endTime])
}

model MaintenanceRequest {
  id               String   @id @default(uuid())
  assetId          String
  asset            Asset    @relation(fields: [assetId], references: [id])
  raisedById       String
  raisedBy         User     @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  issueDescription String
  priority         MaintenancePriority @default(MEDIUM)
  photoUrl         String?
  status           MaintenanceStatus @default(PENDING)
  approvedById     String?
  approvedBy       User?    @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])
  technicianName   String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([assetId, status])
}

model AuditCycle {
  id                String   @id @default(uuid())
  name              String
  scopeDepartmentId String?
  scopeLocation     String?
  startDate         DateTime
  endDate           DateTime
  status            AuditCycleStatus @default(OPEN)
  createdById       String
  createdBy         User     @relation("AuditCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime @default(now())
  closedAt          DateTime?

  auditors AuditCycleAuditor[]
  items    AuditItem[]
}

model AuditCycleAuditor {
  id           String     @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  auditorId    String
  auditor      User       @relation(fields: [auditorId], references: [id])

  @@unique([auditCycleId, auditorId])
}

model AuditItem {
  id           String     @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  assetId      String
  asset        Asset      @relation(fields: [assetId], references: [id])
  result       AuditResult?
  notes        String?
  checkedAt    DateTime?

  @@unique([auditCycleId, assetId])
}

model Notification {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  type              NotificationType
  message           String
  isRead            Boolean  @default(false)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime @default(now())

  @@index([userId, isRead])
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
